{
  "name": "@curaos/workflow-state-sdk",
  "description": "Typed entity-lifecycle state machines on XState v5. Wraps createMachine/createActor behind a plain states+transitions config so any service can model an entity lifecycle (order draft->submitted->approved->fulfilled, encounter status, etc.) without hand-rolled state logic.",
  "version": "0.0.0",
  "dependencies": {
    "xstate": "5.32.2"
  },
  "devDependencies": {
    "@curaos/tsconfig": "workspace:*",
    "@types/bun": "1.3.14",
    "@types/node": "22.19.19",
    "oxlint": "1.68.0",
    "typescript": "5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "LicenseRef-CuraOS-BSL",
  "main": "./dist/index.js",
  "packageManager": "bun@1.3.14",
  "private": true,
  "publishConfig": {
    "access": "restricted",
    "registry": "http://localhost:4873"
  },
  "scripts": {
    "build": "tsc",
    "lint": "oxlint .",
    "test": "bun test test",
    "test:coverage": "bun test test --coverage",
    "typecheck": "tsc --noEmit"
  },
  "type": "commonjs",
  "types": "./dist/index.d.ts"
}
